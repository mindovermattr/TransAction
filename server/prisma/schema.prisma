generator client {
  provider = "prisma-client-js"
}

enum TransactionTag {
  JOY
  TRANSPORT
  FOOD
  EDUCATION
  HOUSING
  OTHER
}

enum AccountType {
  cash
  debit
  savings
  credit
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int           @id @default(autoincrement())
  email        String        @unique
  name         String
  password     String
  accounts     Account[]
  budgets      Budget[]
  transactions Transaction[]
  incomes      Income[]
  transfers    Transfer[]
}

model Account {
  id                Int        @id @default(autoincrement())
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  name              String
  type              AccountType @default(debit)
  currency          String     @default("RUB")
  openingBalance    Int        @default(0) @map("opening_balance")
  isArchived        Boolean    @default(false) @map("is_archived")

  user              User       @relation(fields: [userId], references: [id])
  userId            Int        @map("user_id")
  transactions      Transaction[]
  incomes           Income[]
  outgoingTransfers Transfer[] @relation("TransferFromAccount")
  incomingTransfers Transfer[] @relation("TransferToAccount")

  @@index([userId])
}

model Budget {
  id         Int            @id @default(autoincrement())
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  monthStart DateTime       @map("month_start")
  tag        TransactionTag
  limit      Int
  isArchived Boolean        @default(false) @map("is_archived")

  user       User           @relation(fields: [userId], references: [id])
  userId     Int            @map("user_id")

  @@index([userId])
  @@index([userId, monthStart])
  @@index([userId, tag, monthStart, isArchived])
}

model Transaction {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name  String
  tag   TransactionTag
  price Int
  date  DateTime

  user    User    @relation(fields: [userId], references: [id])
  userId  Int     @map("user_id")
  account Account @relation(fields: [accountId], references: [id])
  accountId Int   @map("account_id")

  @@index([userId])
  @@index([accountId])
}

model Income {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name  String
  price Int
  date  DateTime

  user    User    @relation(fields: [userId], references: [id])
  userId  Int     @map("user_id")
  account Account @relation(fields: [accountId], references: [id])
  accountId Int   @map("account_id")

  @@index([userId])
  @@index([accountId])
}

model Transfer {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  amount Int
  date   DateTime
  note   String?

  user          User    @relation(fields: [userId], references: [id])
  userId        Int     @map("user_id")
  fromAccount   Account @relation("TransferFromAccount", fields: [fromAccountId], references: [id])
  fromAccountId Int     @map("from_account_id")
  toAccount     Account @relation("TransferToAccount", fields: [toAccountId], references: [id])
  toAccountId   Int     @map("to_account_id")

  @@index([userId])
  @@index([fromAccountId])
  @@index([toAccountId])
}
